# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3005
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/nexuspm
JWT_SECRET=replace-with-strong-secret
CLIENT_URL=http://localhost:3005
CLIENT_URLS=http://localhost:3005,http://127.0.0.1:3005
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Render frontend service
# Keep NODE_ENV unset on the frontend service unless you set it to exactly `production`.
# NEXT_PUBLIC_APP_URL=https://your-frontend.onrender.com
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# Render backend service
# NODE_ENV=production
# PORT=10000
# MONGO_URI=your_mongodb_uri
# JWT_SECRET=your_strong_jwt_secret
# CLIENT_URL=https://your-frontend.onrender.com
# CLIENT_URLS=https://your-frontend.onrender.com
# GOOGLE_CLIENT_ID=your_google_client_id
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_google_app_password
# SMTP_FROM=your_email@gmail.com
